<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/txtSearchConditionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/search_condition_title"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/layoutConditionChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/layoutFilterCondition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtFilterConditionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_condition_filter_label"
                    android:textAppearance="?attr/textAppearanceBody1" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilterCondition"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:singleLine="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutExcludeCondition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtExcludeConditionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_condition_exclude_label"
                    android:textAppearance="?attr/textAppearanceBody1" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupExcludeCondition"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:singleLine="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAnyCondition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtAnyConditionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_condition_any_label"
                    android:textAppearance="?attr/textAppearanceBody1" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupAnyCondition"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:singleLine="false" />
            </LinearLayout>
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <androidx.constraintlayout.helper.widget.Flow
                android:id="@+id/flowConditionButtons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="btnAddFilterCondition,btnAddExcludeCondition,btnAddAnyCondition"
                app:flow_horizontalGap="8dp"
                app:flow_verticalGap="8dp"
                app:flow_wrapMode="chain"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddFilterCondition"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/btn_add_filter_condition"
                android:textSize="12sp"
                app:icon="@drawable/ic_plus_24"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:iconPadding="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddExcludeCondition"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/btn_add_exclude_condition"
                android:textSize="12sp"
                app:icon="@drawable/ic_plus_24"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:iconPadding="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddAnyCondition"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/btn_add_any_condition"
                android:textSize="12sp"
                app:icon="@drawable/ic_plus_24"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:iconPadding="2dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelSearchCondition"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/btn_cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmSearchCondition"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:text="@string/btn_confirm_search_condition" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
