    <string name="dlg_title_notification_access_required">Notification access required</string>
    <string name="dlg_msg_notification_access_required">
        Smart Notifire is an app that reads notifications aloud based on rules you define.\n\n
        To enable this feature, you need to grant the Android "Notification Access" permission.\n\n
        This app only uses the information necessary to identify notifications\n
        (such as app name and channel information) and the notification title.\n
        It does NOT collect, store, or transmit notification content or personal data.\n\n
        For more details on how your data is handled, please see our Privacy Policy:
    </string>
    <string name="dlg_msg_notification_access_required_part2">
        \nTap "OK" to open the settings screen.\n
        Find Smart Notifire in the list and enable the permission.\n
        You may choose not to grant this permission.\n\n
        In that case, select "Exit App" to close the application.\n
    </string>
